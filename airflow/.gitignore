# Airflow database
airflow.db
airflow.db-journal

# Airflow configuration (may contain sensitive data)
airflow.cfg

# Logs
logs/

# Python cache
__pycache__/
*.pyc
*.pyo

# Environment files
.env
.venv

# Environment-specific directories (not versioned, except dags/)
