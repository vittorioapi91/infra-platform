# env and runtime
.env*
.DS_Store
*.log
*.pyc
__pycache__/
prisma/node_modules/

# storage-postgresql: keep folder structure, ignore Postgres data inside (dev|test|prod may be symlinks to SSD)
storage-postgresql/dev/*
!storage-postgresql/dev/.gitkeep
storage-postgresql/test/*
!storage-postgresql/test/.gitkeep
storage-postgresql/prod/*
!storage-postgresql/prod/.gitkeep

# storage-other-data: keep folder structure, ignore DAG output files inside
storage-other-data/ta/dev/*
!storage-other-data/ta/dev/.gitkeep
storage-other-data/ta/test/*
!storage-other-data/ta/test/.gitkeep
storage-other-data/ta/prod/*
!storage-other-data/ta/prod/.gitkeep
storage-other-data/pma/dev/*
!storage-other-data/pma/dev/.gitkeep
storage-other-data/pma/test/*
!storage-other-data/pma/test/.gitkeep
storage-other-data/pma/prod/*
!storage-other-data/pma/prod/.gitkeep

# jenkins: runtime data (plugins, war, builds, workspaces); use storage-infra/jenkins/data
jenkins/data/

# storage-infra: keep <service>/data structure, ignore contents inside data/
storage-infra/prometheus/data/*
!storage-infra/prometheus/data/.gitkeep
storage-infra/grafana/data/*
!storage-infra/grafana/data/.gitkeep
storage-infra/mlflow/data/*
!storage-infra/mlflow/data/.gitkeep
storage-infra/redisinsight/data/*
!storage-infra/redisinsight/data/.gitkeep
storage-infra/nats/data/*
!storage-infra/nats/data/.gitkeep
storage-infra/openproject/data/*
!storage-infra/openproject/data/.gitkeep
storage-infra/openproject-postgres/data/*
storage-infra/registry/data/*
!storage-infra/registry/data/.gitkeep
storage-infra/portainer/data/*
!storage-infra/portainer/data/.gitkeep
storage-infra/jenkins/data/*
!storage-infra/jenkins/.gitkeep

# storage-infra/airflow: db (Airflow home), wheels, workspace/package_root, logs (not versioned)
storage-infra/airflow/dev/db/*
!storage-infra/airflow/dev/db/.gitkeep
storage-infra/airflow/dev/wheels/*
!storage-infra/airflow/dev/wheels/.gitkeep
storage-infra/airflow/dev/workspace/*
!storage-infra/airflow/dev/workspace/.gitkeep
storage-infra/airflow/dev/logs/*
!storage-infra/airflow/dev/logs/.gitkeep
storage-infra/airflow/test/db/*
!storage-infra/airflow/test/db/.gitkeep
storage-infra/airflow/test/wheels/*
!storage-infra/airflow/test/wheels/.gitkeep
storage-infra/airflow/test/package_root/*
!storage-infra/airflow/test/package_root/.gitkeep
storage-infra/airflow/test/logs/*
!storage-infra/airflow/test/logs/.gitkeep
storage-infra/airflow/prod/db/*
!storage-infra/airflow/prod/db/.gitkeep
storage-infra/airflow/prod/wheels/*
!storage-infra/airflow/prod/wheels/.gitkeep
storage-infra/airflow/prod/package_root/*
!storage-infra/airflow/prod/package_root/.gitkeep
storage-infra/airflow/prod/logs/*
!storage-infra/airflow/prod/logs/.gitkeep
